{
  "name": "iie",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OHCS Intelligent Integration Engine — event-driven process intelligence on Cloudflare",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "check": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply iie-event-log --local",
    "db:migrate:remote": "wrangler d1 migrations apply iie-event-log --remote",
    "seed": "node scripts/seed.mjs",
    "validate": "node scripts/validate.mjs",
    "test": "vitest run",
    "build:web": "npm --prefix web run build",
    "check:web": "npm --prefix web run typecheck"
  },
  "dependencies": {
    "hono": "^4.12.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.7",
    "@cloudflare/workers-types": "^5.20260723.1",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.113.0"
  }
}
